#!/usr/bin/env bash
# ==============================================================================
# OKnav - Individual Server SSH Handler
# ==============================================================================
#
# SSH connection handler invoked via symlinks. The symlink name (srv1, ok0,
# etc.) is resolved through hosts.conf to determine the target FQDN.
#
# On SSH connection failure (exit 255), optionally retries through a relay
# host via ProxyCommand (nc). Relay configured via /etc/oknav/relay.conf,
# OKNAV_RELAY env, --relay flag, or disabled with --no-relay. See usage
# for priority order.
#
# Resolution order:
#   1. Look up symlink name in hosts.conf → FQDN
#   2. If not found, use symlink name directly as hostname (ad-hoc)
#
# Exit codes:
#   0   Success
#   1   General error
#   2   Local-only constraint violated (server restricted to specific host)
#   22  Invalid option (EINVAL)
#   42  Direct execution (must invoke via symlink, not as 'ok_master')
#
# Related:
#   oknav          - Cluster orchestrator (multi-server commands)
#   common.inc.sh  - Shared configuration and functions
#   hosts.conf     - Server definitions (FQDN → alias mappings)
#
# ==============================================================================
set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob nullglob

#shellcheck disable=SC2155
declare -r SCRIPT_PATH=$(realpath -- "$0")
declare -r SCRIPT_DIR=${SCRIPT_PATH%/*}
declare -r SCRIPT_NAME=${SCRIPT_PATH##*/}

#shellcheck source=common.inc.sh
source "$SCRIPT_DIR"/common.inc.sh || exit 1

# ------------------------------------------------------------------------------
# Configuration (derived from invocation and options)
# ------------------------------------------------------------------------------
declare -- SERVER=${0##*/}         # Target: symlink name, NOT readlink result
declare -- USER=${USER:-root}      # SSH user (current user or root fallback)
declare -- CURDIR=''               # Remote directory (-d preserves PWD)
declare -- CMD=''                  # Remote command (empty = interactive shell)
declare -- SSHOPTS=''              # SSH options (-t for interactive)
declare -i CONNECT_TIMEOUT=${OKNAV_CONNECT_TIMEOUT:-10}  # SSH handshake timeout
declare -- RELAY=''                # Relay host for ProxyCommand failover
declare -i NO_RELAY=0             # Disable relay for this invocation

usage() {
  cat <<HELP
$SERVER $VERSION - Individual server SSH handler

Usage:
  $SERVER [OPTIONS] [COMMAND...]    Execute command on server
  $SERVER [OPTIONS]                 Start interactive shell

Options:
  -r, --root                Connect as root
  -u, --user USER           Connect as specified user
  -c, --connect-timeout S   SSH connect timeout in seconds (default: $CONNECT_TIMEOUT)
  -d, --dir                 Preserve current working directory
  -R, --relay HOST          Use HOST as relay on connection failure
  --no-relay                Disable relay failover for this invocation
  -D, --debug               Show connection parameters before connecting
  -V, --version             Show version
  -h, --help                Show this help

Relay Failover:
  On SSH connection failure (exit 255), retry via ProxyCommand (nc) through a relay.
  Priority: --relay flag > OKNAV_RELAY env > /etc/oknav/relay.conf
  Set OKNAV_RELAY=none to disable. Use non-WG endpoints for WG outages.

Examples:
  $SERVER uptime                    Run 'uptime' on server
  $SERVER -r                        Root shell
  $SERVER -rd                       Root shell in current directory
  $SERVER -u deploy git pull        Run as specific user
  $SERVER "df -h | grep data"       Commands with pipes (quote them)
  $SERVER --relay user@1.2.3.4 cmd  Force relay through specific host

Server Resolution:
  Symlink name '$SERVER' is looked up in hosts.conf to get FQDN.
  If not found, '$SERVER' is used directly as hostname.
HELP
}

# ------------------------------------------------------------------------------
# Option Parsing (supports combined short options: -rd → -r -d)
# ------------------------------------------------------------------------------
while (($#)); do
  case $1 in
    -u|--user)    shift; USER=${1:-"${USER:-}"} ;;
    -r|--root)    USER=root ;;
    -c|--connect-timeout)
      shift
      CONNECT_TIMEOUT=${1:-10}
      [[ "$CONNECT_TIMEOUT" =~ ^[0-9]+$ ]] || die 22 "Invalid connect-timeout value ${CONNECT_TIMEOUT@Q}" ;;
    -d|--dir)     CURDIR=$PWD ;;
    -R|--relay)   shift; RELAY=${1:-}; [[ -n "$RELAY" ]] || die 22 "--relay requires a host" ;;
    --no-relay)   NO_RELAY=1 ;;
    -D|--debug)   DEBUG=1 ;;
    -V|--version) echo "$SCRIPT_NAME $VERSION"; exit 0 ;;
    -h|--help)    usage; exit 0 ;;

    -[ucrdDVhR]*) # Expand combined options: -rd → -r -d
                  # Note: -u/-c/-R take arguments and must not be combined
                  #shellcheck disable=SC2046
                  set -- '' $(printf -- '-%c ' $(grep -o . <<<"${1:1}")) "${@:2}" ;;

    -*)           die 22 "Invalid option ${1@Q}" ;;
    *)            CMD="$*"; break ;;  # Remaining args form the remote command
  esac
  shift
done

# Sanity check: must be invoked via symlink, not directly as 'ok_master'
if [[ $(basename -- "$SERVER") == "$SCRIPT_NAME" ]]; then
  die 42 \
    "Cannot run ${SCRIPT_NAME@Q} directly." '' \
    'Create a symlink with the server name you want to connect to:' \
    "  ln -s $(command -v ok_master || echo /usr/local/bin/ok_master) /usr/local/bin/myserver" '' \
    'Then connect with:' \
    '  myserver uptime' '' \
    'Or use oknav to manage symlinks:' \
    '  oknav add myserver.example.com myserver' \
    '  oknav list'
fi

# ------------------------------------------------------------------------------
# get_relay() - Resolve relay host from CLI flag, env var, or config file
# Returns: 0 with relay host on stdout, 1 if no relay configured
# Priority: --relay flag → OKNAV_RELAY env → /etc/oknav/relay.conf
# ------------------------------------------------------------------------------
get_relay() {
  # CLI flag already set RELAY — return it
  [[ -n "$RELAY" ]] && { echo "$RELAY"; return 0; }
  # Environment variable
  if [[ -n "${OKNAV_RELAY:-}" ]]; then
    [[ "$OKNAV_RELAY" == none ]] && return 1
    echo "$OKNAV_RELAY"
    return 0
  fi
  # Config file
  local -- conf='/etc/oknav/relay.conf'
  [[ -f "$conf" ]] || return 1
  local -- line
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    echo "${line%%[[:space:]]*}"
    return 0
  done < "$conf"
  return 1
}

# ------------------------------------------------------------------------------
# Server Resolution: symlink name → FQDN via hosts.conf
# Returns: 0 found, 1 not found (use as hostname), 2 constraint violation
# ------------------------------------------------------------------------------
#shellcheck disable=SC2119
load_hosts_conf
declare -- ALIAS="$SERVER"
SERVER=$(resolve_alias "$ALIAS") || {
  case $? in
    1) SERVER="$ALIAS" ;;  # Not in hosts.conf: use alias as hostname
    2) exit 2 ;;           # Local-only constraint violated (error printed)
  esac
}

# ------------------------------------------------------------------------------
# Command Setup: interactive shell vs command execution
# ------------------------------------------------------------------------------
if [[ -z "$CMD" ]]; then
  CMD='exec bash'
  SSHOPTS='-t'  # Pseudo-terminal for interactive session
fi

# Prepend cd if -d option used (path escaped for special chars)
[[ -z "$CURDIR" ]] || CMD="cd $(printf %q "$CURDIR") && $CMD"

# Debug: show connection parameters
if ((DEBUG)); then
  declare -- _relay
  _relay=$(get_relay) || _relay='<none>'
  ((NO_RELAY)) && _relay='<disabled>'
  >&2 echo "DEBUG: Connection parameters:"
  >&2 echo "  ALIAS   = $ALIAS"
  >&2 echo "  SERVER  = $SERVER"
  >&2 echo "  USER    = $USER"
  >&2 echo "  CONN_TIMEOUT = ${CONNECT_TIMEOUT}s"
  >&2 echo "  RELAY   = $_relay"
  [[ -z "$CURDIR" ]] || >&2 echo "  CURDIR  = $CURDIR"
  >&2 echo "  COMMAND = ${CMD:-<interactive shell>}"
  >&2 echo "  SSH     = ssh -o ConnectTimeout=$CONNECT_TIMEOUT $SSHOPTS ${USER}@${SERVER}"
  >&2 echo
fi

# ------------------------------------------------------------------------------
# Execute SSH (with optional relay failover on connection failure)
# ------------------------------------------------------------------------------
declare -- relay_target=''
if ((! NO_RELAY)); then
  relay_target=$(get_relay) || relay_target=''
fi

if [[ -z "$relay_target" ]]; then
  # No relay configured — exec directly (zero overhead, original behavior)
  exec /usr/bin/ssh -o ConnectTimeout="$CONNECT_TIMEOUT" $SSHOPTS "${USER}@${SERVER}" "$CMD"
fi

# Relay configured — try direct first, relay on exit 255
declare -i ssh_exit=0
/usr/bin/ssh -o ConnectTimeout="$CONNECT_TIMEOUT" $SSHOPTS "${USER}@${SERVER}" "$CMD" \
  || ssh_exit=$?

if ((ssh_exit == 255)); then
  info "Direct connection failed, relaying via ${relay_target}..."
  exec /usr/bin/ssh \
    -o "ProxyCommand=ssh -o ConnectTimeout=${CONNECT_TIMEOUT} ${relay_target} 'exec nc -w ${CONNECT_TIMEOUT} %h %p'" \
    -o ConnectTimeout="$CONNECT_TIMEOUT" \
    -o ServerAliveInterval=5 -o ServerAliveCountMax=2 \
    $SSHOPTS "${USER}@${SERVER}" "$CMD"
fi
exit "$ssh_exit"
#fin
